---
---

<footer class="border-t-2 border-dashed border-ink/20 mt-16">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <p class="text-graphite text-sm text-center sm:text-left">
        &copy; {new Date().getFullYear()} Hantekeningen. Alle rechten voorbehouden.
      </p>

      <div class="flex items-center gap-4">
        <a
          href="#"
          aria-label="Instagram"
          class="w-10 h-10 flex items-center justify-center border-2 border-dashed border-ink/60 rounded-full text-ink hover:bg-ink hover:text-paper transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
          </svg>
        </a>

        <a
          href="#"
          aria-label="Pinterest"
          class="w-10 h-10 flex items-center justify-center border-2 border-dashed border-ink/60 rounded-full text-ink hover:bg-ink hover:text-paper transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="9" x2="9" y1="9" y2="15"/>
            <path d="M12 21a9 9 0 1 0-9-9c0 4.97 4.03 9 9 9z"/>
            <path d="M9 15l3-6"/>
            <circle cx="12" cy="7" r="1.5"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
