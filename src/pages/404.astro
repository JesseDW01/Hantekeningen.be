---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Pagina niet gevonden | Hantekeningen.be" description="Deze pagina bestaat niet.">
  <main class="min-h-[70vh] flex flex-col items-center justify-center px-6 py-20 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-6xl font-bold text-ink mb-6">404</h1>
      <p class="text-2xl text-graphite mb-8">Pagina niet gevonden</p>
      <p class="text-lg text-graphite mb-10">
        Deze tekening is nog niet klaar, of de pagina bestaat niet.
      </p>
      <a href="/" class="ink-button text-lg px-8 py-3">
        Terug naar home
      </a>
    </div>
  </main>
</BaseLayout>
